{
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": null,
    "editor.codeActionsOnSave": {}
  },
  "prettier.disableLanguages": ["markdown"],
  "files.associations": {
    "*.md": "markdown"
  },
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "[markdown][mdx]": {
    "editor.formatOnSave": false
  }
}
